        <div class="features-grid">
            <div class="feature-block">
                <h3>Slapen</h3>
                <ul class="feature-list">
                    <li>Max. 5 personen</li>
                    <li>Slaapkamer 1: tweepersoons bed</li>
                    <li>Slaapkamer 2: 3 losse bedden</li>
                    <li>Beddengoed en handdoeken inbegrepen</li>
                </ul>
            </div>
            <div class="feature-block">
                <h3>Keuken</h3>
                <ul class="feature-list">
                    <li>Volledig uitgeruste keuken</li>
                    <li>Vaatwasser</li>
                    <li>Nespresso-apparaat</li>
                    <li>Kookplaat, oven, koelkast</li>
                </ul>
            </div>
            <div class="feature-block">
                <h3>Badkamer</h3>
                <ul class="feature-list">
                    <li>Regendouche met warmteterugwinning</li>
                    <li>Wastafel</li>
                    <li>Toilet</li>
                </ul>
            </div>
            <div class="feature-block">
                <h3>Duurzaamheid</h3>
                <ul class="feature-list">
                    <li>Biobased constructie</li>
                    <li>Passiefhuis-principe</li>
                    <li>Leemstuc wanden</li>
                    <li>Vloerverwarming via warmtepomp</li>
                </ul>
            </div>
            <div class="feature-block">
                <h3>Buiten</h3>
                <ul class="feature-list">
                    <li>Eigen terras met tuinmeubilair</li>
                    <li>Uitzicht op het voedselbos</li>
                    <li>Veel privacy</li>
                    <li>Parkeren op het terrein, kort stukje lopen naar het huisje</li>
                </ul>
            </div>
            <div class="feature-block">
                <h3>Overig</h3>
                <ul class="feature-list">
                    <li>Wasmachine</li>
                    <li>Wi-Fi</li>
                    <li>Geen huisdieren</li>
                </ul>
            </div>
        </div>
    </div>
</section>

