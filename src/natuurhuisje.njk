            </div>
        </div>

        <!-- Hoofdfoto -->
        <div class="acasia-hero-photo" style="margin-top: 50px;">
            <img loading="lazy" src="{{ pagina_natuurhuisje.hero.hoofdfoto }}" alt="{{ pagina_natuurhuisje.hero.hoofdfoto_alt }}">
        </div>

