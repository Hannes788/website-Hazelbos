        <p class="section-text" style="margin-top: 16px;">{{ pagina_natuurhuisje.huisje.tekst2 }}</p>
        {% endif %}

        <!-- Fotogalerij -->
        <div class="grid-3 gallery" style="margin-top: 40px;">
            {% for foto in pagina_natuurhuisje.huisje.fotos %}
            <div class="gallery-item">
                <img loading="lazy" src="{{ foto.src }}" alt="{{ foto.alt }}">
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<div class="sketch-divider"></div>

<!-- ==================== VOORZIENINGEN ==================== -->
<section class="section">
    <div class="fade-in">
