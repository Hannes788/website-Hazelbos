                <span class="section-label">{{ pagina_natuurhuisje.hero.label }}</span>
                <h1 class="section-title">{{ pagina_natuurhuisje.hero.titel }}</h1>
                <p class="section-text">{{ pagina_natuurhuisje.hero.tekst }}</p>
            </div>
            <div class="hero-split-image">
