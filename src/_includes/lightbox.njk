<div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Foto vergroting">
    <button class="lightbox-close" id="lightboxClose" aria-label="Sluiten">&times;</button>
    <button class="lightbox-prev" id="lightboxPrev" aria-label="Vorige foto">&#8249;</button>
    <button class="lightbox-next" id="lightboxNext" aria-label="Volgende foto">&#8250;</button>
    <img src="" alt="" class="lightbox-img" id="lightboxImg">
    <p class="lightbox-caption" id="lightboxCaption"></p>
</div>
