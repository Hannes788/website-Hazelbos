        "url": "https://hazelbos.nl/groepsruimte",
        "telephone": "+31623502163",
        "email": "info@hazelbos.nl",
        "address": {
            "@type": "PostalAddress",
            "streetAddress": "Akkermansstraat 8",
            "postalCode": "7021 LW",
            "addressLocality": "Zelhem",
            "addressRegion": "Gelderland",
            "addressCountry": "NL"
        },
        "geo": {
            "@type": "GeoCoordinates",
            "latitude": 52.0058,
            "longitude": 6.3475
        },
        "maximumAttendeeCapacity": 30,
        "floorSize": {
            "@type": "QuantitativeValue",
            "value": 60,
            "unitCode": "MTK"
        },
        "amenityFeature": [
            { "@type": "LocationFeatureSpecification", "name": "Keuken", "value": true },
            { "@type": "LocationFeatureSpecification", "name": "Douche", "value": true },
            { "@type": "LocationFeatureSpecification", "name": "Toilet", "value": true },
            { "@type": "LocationFeatureSpecification", "name": "Parkeerplaatsen", "value": true },
            { "@type": "LocationFeatureSpecification", "name": "Buitenruimte en vuurcirkel", "value": true }
        ],
        "offers": [
            {
                "@type": "Offer",
                "name": "Dagdeel",
                "price": "125",
                "priceCurrency": "EUR",
                "description": "Ochtend, middag of avond. Inclusief koffie en thee."
            },
            {
                "@type": "Offer",
                "name": "Hele dag",
                "price": "350",
                "priceCurrency": "EUR",
                "description": "08:00 – 22:30. Inclusief koffie en thee."
            },
            {
                "@type": "Offer",
                "name": "Weekend",
                "price": "550",
                "priceCurrency": "EUR",
                "description": "Zaterdag en zondag. Inclusief koffie en thee."
            }
        ],
