permalink: /groepsruimte/
---

<!-- ==================== HERO ==================== -->
<section class="section" id="top">
    <div class="fade-in">
        <div class="hero-split">
            <div class="hero-split-text">
                <span class="section-label">{{ pagina_groepsruimte.hero.label }}</span>
                <h1 class="section-title">{{ pagina_groepsruimte.hero.titel }}</h1>
                <p class="section-text">{{ pagina_groepsruimte.hero.tekst }}</p>
            </div>
            <div class="hero-split-image">
                <img src="/images/schetsen/groepsruimte%20schets.png" alt="Potloodschets van de groepsruimte">
            </div>
        </div>

        <div class="grid-3 gallery" style="margin-top: 40px;">
            {% for foto in pagina_groepsruimte.hero.fotos %}
            <div class="gallery-item">
                <img loading="lazy" src="{{ foto.src }}" alt="{{ foto.alt }}">
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<div class="sketch-divider"></div>

<!-- ==================== DE RUIMTE ==================== -->
<section class="section">
    <div class="fade-in">
        <span class="section-label">{{ pagina_groepsruimte.ruimte.label }}</span>
        <h2 class="section-title">{{ pagina_groepsruimte.ruimte.titel }}</h2>
        <p class="section-text">{{ pagina_groepsruimte.ruimte.tekst }}</p>
        {% if pagina_groepsruimte.ruimte.tekst2 %}
        <p class="section-text" style="margin-top: 16px;">{{ pagina_groepsruimte.ruimte.tekst2 }}</p>
        {% endif %}

        <div class="grid-3 gallery" style="margin-top: 40px;">
            {% for foto in pagina_groepsruimte.ruimte.fotos %}
            <div class="gallery-item">
                <img loading="lazy" src="{{ foto.src }}" alt="{{ foto.alt }}">
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<div class="sketch-divider"></div>

<!-- ==================== VOORZIENINGEN ==================== -->
<section class="section">
    <div class="fade-in">
        <span class="section-label">voorzieningen</span>
        <h2 class="section-title">Wat is er aanwezig</h2>

        <div class="features-grid" style="margin-top: 30px;">
            {% for item in pagina_groepsruimte.voorzieningen %}
            <div class="feature-block">
                <h3>{{ item.titel }}</h3>
                <p>{{ item.tekst }}</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<div class="sketch-divider"></div>

<!-- ==================== PRIJZEN ==================== -->
<section class="section">
    <div class="fade-in">
        <span class="section-label">prijzen</span>
        <h2 class="section-title">Tarieven</h2>

        <table class="tariff-table" style="margin-top: 30px;">
            <thead>
                <tr>
                    <th>Optie</th>
                    <th>Tijden</th>
                    <th>Tarief (incl. btw)</th>
                </tr>
            </thead>
            <tbody>
                {% for tarief in groepsruimte_prijzen.tarieven %}
                <tr>
                    <td>{{ tarief.optie }}</td>
                    <td>{{ tarief.tijden }}</td>
                    <td>{{ tarief.prijs }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        <p class="section-text" style="margin-top: 16px; font-size: 0.9em;">{{ groepsruimte_prijzen.opmerking }}</p>
    </div>
</section>

<div class="sketch-divider"></div>

<!-- ==================== SFEER ==================== -->
<section class="section">
    <div class="fade-in">
        <span class="section-label">{{ pagina_groepsruimte.sfeer.label }}</span>
        <h2 class="section-title">{{ pagina_groepsruimte.sfeer.titel }}</h2>
        <p class="section-text">{{ pagina_groepsruimte.sfeer.tekst }}</p>

        <div class="grid-3 gallery" style="margin-top: 40px;">
            {% for foto in pagina_groepsruimte.sfeer.fotos %}
            <div class="gallery-item">
                <img loading="lazy" src="{{ foto.src }}" alt="{{ foto.alt }}">
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<div class="sketch-divider"></div>

<!-- ==================== CONTACT ==================== -->
<section class="section">
    <div class="fade-in">
        <span class="section-label">{{ pagina_groepsruimte.contact.label }}</span>
        <h2 class="section-title">{{ pagina_groepsruimte.contact.titel }}</h2>
        <p class="section-text">{{ pagina_groepsruimte.contact.tekst }}</p>
        <div style="margin-top: 20px; text-align: center;">
            <a href="mailto:{{ site.email }}?subject=Groepsruimte%20huren" class="btn btn-filled">Stuur een e-mail</a>
            <a href="tel:{{ site.phone }}" class="read-more" style="margin-left: 20px;">bel ons &rarr;</a>
        </div>
    </div>
</section>
