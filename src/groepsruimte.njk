<!-- ==================== HERO ==================== -->
<section class="section" id="top">
    <div class="fade-in">
        <div class="hero-split">
            <div class="hero-split-text">
                <span class="section-label">groepsruimte</span>
                <h1 class="section-title">Vergaderen en samenkomen</h1>
                <p class="section-text">Een rustige vergader- en workshopruimte van 60m², midden in het voedselbos van 't Hazelbos. Geschikt voor vergaderingen, brainstormsessies, workshops, cursussen en lezingen. Met flexibele indelingen en alle benodigde faciliteiten voor groepen tot 30 personen.</p>
            </div>
            <div class="hero-split-image">
                <img src="/images/schetsen/groepsruimte%20schets.png" alt="Potloodschets van de groepsruimte">
            </div>
        </div>

