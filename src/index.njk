<!-- ==================== VOEDSELBOS (HERO) ==================== -->
<section class="section hero-section" id="voedselbos">
    <h1 class="visually-hidden">'t Hazelbos</h1>
    <div class="fade-in hero-split">
        <div class="hero-split-text">
            <span class="section-label">voedselbos</span>
            <h2 class="section-title">Ons levende voedselbos</h2>
            <p class="section-text">Een divers ecosysteem waar fruitbomen, bessenstruiken, kruiden en groenten samen groeien. Een plek waar natuur en voedselproductie hand in hand gaan.</p>
        </div>
        <div class="hero-split-image">
            <img src="/images/schetsen/schets%20vervloeid%20perzik.png" alt="Potloodschets van een perzik aan de boom">
        </div>
    </div>

    <div class="grid-3 gallery">
        <div class="gallery-item">
            <img src="/images/fotos/voedselbos/avondlicht-bomen.jpg" alt="Avondlicht door de bomen in het voedselbos">
        </div>
        <div class="gallery-item">
            <img src="/images/fotos/voedselbos/vuurcirkel-ochtend.jpg" alt="Vuurcirkel bij zonsopkomst">
        </div>
        <div class="gallery-item">
            <img src="/images/fotos/voedselbos/kas.jpg" alt="Kas in het voedselbos">
        </div>
        <div class="gallery-item">
            <img src="/images/fotos/voedselbos/tomaten-kas.jpg" alt="Tomaten rijpen in de kas">
        </div>
        <div class="gallery-item">
            <img src="/images/fotos/voedselbos/bessen.jpg" alt="Bessen aan de struik">
        </div>
        <div class="gallery-item">
            <img src="/images/fotos/voedselbos/kornoelje.jpg" alt="Kornoelje in bloei">
        </div>
        <div class="gallery-item">
            <img src="/images/fotos/voedselbos/bloem-zonsondergang.jpg" alt="Bloem bij zonsondergang">
        </div>
        <div class="gallery-item">
            <img src="/images/fotos/voedselbos/bij-verbena.jpg" alt="Bij op verbena">
        </div>
        <div class="gallery-item">
            <img src="/images/fotos/voedselbos/ochtendmist.jpg" alt="Ochtendmist in het voedselbos">
        </div>
    </div>

    <a href="/voedselbos/" class="read-more">lees meer over ons voedselbos &rarr;</a>
</section>

<div class="sketch-divider"></div>

<!-- ==================== NATUURHUISJE ==================== -->
<section class="section" id="natuurhuisje">
    <div class="fade-in">
        <div class="hero-split">
            <div class="hero-split-text">
                <span class="section-label">verblijf</span>
                <h2 class="section-title">Acasia</h2>
                <p class="section-text">Ons natuurhuisje, midden in het voedselbos. Omringd door groen en met veel privacy. Met zorg ingericht en alles wat je nodig hebt voor een ontspannen verblijf in de natuur.</p>
            </div>
            <div class="hero-split-image">
                <img src="/images/schetsen/schets%20huisje%20vervloeid.png" alt="Potloodschets van het natuurhuisje">
            </div>
        </div>

        <!-- Hoofdfoto -->
        <div class="acasia-hero-photo" style="margin-top: 50px;">
            <img src="/images/fotos/acasia/huisje-3.png" alt="Acasia — natuurhuisje midden in het voedselbos">
        </div>

        <!-- Fotogalerij -->
        <div class="grid-3 gallery" style="margin-top: 24px;">
            <div class="gallery-item">
                <img src="/images/fotos/acasia/woonkamer-glaswand.png" alt="Woonkamer met grote glaswand en uitzicht op het bos">
            </div>
            <div class="gallery-item">
                <img src="/images/fotos/acasia/woonkamer-overzicht.png" alt="Eethoek en woonkamer">
            </div>
            <div class="gallery-item">
                <img src="/images/fotos/acasia/keuken.png" alt="Volledig uitgeruste keuken">
            </div>
            <div class="gallery-item">
                <img src="/images/fotos/acasia/uitzicht-bos.png" alt="Uitzicht vanuit het huisje op het bos">
            </div>
            <div class="gallery-item">
                <img src="/images/fotos/acasia/slaapkamer-tweepersoons.png" alt="Slaapkamer met tweepersoons bed">
            </div>
            <div class="gallery-item">
                <img src="/images/fotos/acasia/slaapkamer-bedden.png" alt="Slaapkamer met losse bedden">
            </div>
            <div class="gallery-item">
                <img src="/images/fotos/acasia/badkamer-wastafel.png" alt="Badkamer met koperen kraan">
            </div>
            <div class="gallery-item">
                <img src="/images/fotos/acasia/regendouche.png" alt="Regendouche">
            </div>
            <div class="gallery-item">
                <img src="/images/fotos/acasia/spiegeltje.png" alt="Handgemaakt houten spiegeltje">
            </div>
        </div>

        <ul class="feature-list" style="margin-top: 40px;">
            <li><strong>Capaciteit:</strong> max. 5 personen</li>
            <li><strong>Faciliteiten:</strong> keuken, badkamer, terras met uitzicht op het voedselbos</li>
            <li><strong>Ligging:</strong> midden in het voedselbos, veel privacy</li>
        </ul>

        <!-- Smoobu boekingswidget -->
        <div class="booking-widget" style="margin-top: 50px;">
            <button class="btn btn-filled" id="bookingToggle" onclick="toggleBooking()">Bekijk beschikbaarheid & boek</button>
            <div id="bookingContent" class="booking-content" style="position:relative;">
                <div style="position:absolute;top:22px;right:22px;width:40px;height:40px;z-index:9999;cursor:default;background:white;"></div>
                <div id="apartmentIframe3235012" class="smoobu-wrapper">
                    <script type="text/javascript" src="https://login.smoobu.com/js/Settings/BookingToolIframe.js"></script>
                    <script>BookingToolIframe.initialize({"url": "https://login.smoobu.com/en/booking-tool/iframe/1685922/3235012", "baseUrl": "https://login.smoobu.com", "target": "#apartmentIframe3235012"})</script>
                </div>
            </div>
        </div>

        <a href="/natuurhuisje/" class="read-more">meer over Acasia &rarr;</a>
    </div>
</section>

<div class="sketch-divider"></div>

<!-- ==================== GROEPSRUIMTE ==================== -->
<section class="section hero-section" id="groepsruimte">
    <div class="fade-in hero-split">
        <div class="hero-split-image">
            <img src="/images/schetsen/groepsruimte%20schets.png" alt="Potloodschets van de groepsruimte">
        </div>
        <div class="hero-split-text">
            <span class="section-label">groepsruimte</span>
            <h2 class="section-title">Vergaderen en samenkomen</h2>
            <p class="section-text">Een rustige ruimte van 60m² voor vergaderingen, brainstormsessies, workshops, cursussen en lezingen. Flexibel in te delen, geschikt voor maximaal 30 personen. Neem tijdens een pauze de tijd om het voedselbos te verkennen.</p>
        </div>
    </div>

    <div class="grid-3 gallery" style="margin-top: 30px;">
        <div class="gallery-item">
            <img src="/images/fotos/groepsruimte/totaaloverzicht.jpg" alt="Totaaloverzicht van de ruimte">
        </div>
        <div class="gallery-item">
            <img src="/images/fotos/groepsruimte/cirkelkleed-zithoek.jpg" alt="Cirkelkleed met zithoek en houtkachel">
        </div>
        <div class="gallery-item">
            <img src="/images/fotos/groepsruimte/keuken-uitzicht.jpg" alt="Keuken met uitzicht op het groen">
        </div>
    </div>

    <a href="/groepsruimte/" class="btn btn-filled" style="margin-top: 30px;">Boekingsinformatie</a>
</section>

<div class="sketch-divider"></div>

<!-- ==================== NIEUWS ==================== -->
<section class="section" id="nieuws">
    <div class="fade-in">
        <span class="section-label">nieuws</span>
        <h2 class="section-title">Laatste nieuws</h2>

        <div class="news-grid">
            {% for item in collections.nieuws %}
            <details class="news-card">
                <summary>
                    <p class="date">{{ item.date | dutchDate }}</p>
                    <h3>{{ item.data.title }}</h3>
                    <p>{{ item.data.summary }}</p>
                </summary>
                {% if item.data.image %}
                <img src="{{ item.data.image }}" alt="{{ item.data.imageAlt | default('') }}" style="width: 100%; margin: 16px 0;">
                {% endif %}
                {{ item.templateContent | safe }}
                {% if item.data.title == "1 mei: Acasia gaat open voor verhuur" %}
                <a href="/natuurhuisje/#boeken" class="read-more" style="margin-top: 12px; display: inline-block;">bekijk beschikbaarheid &rarr;</a>
                {% endif %}
            </details>
            {% endfor %}
        </div>
    </div>
</section>

<div class="sketch-divider"></div>

<!-- ==================== WIE ZIJN WIJ ==================== -->
<section class="section" id="wie-zijn-wij">
    <div class="fade-in">
        <span class="section-label">wie zijn wij</span>
        <h2 class="section-title">De mensen achter 't Hazelbos</h2>
        <p class="section-text">{{ team.intro }}</p>
        <p class="section-text" style="margin-top: 16px;">{{ team.intro2 }}</p>

        <div class="team-row">
            {% for person in team.members %}
            <div class="team-person">
                <img src="{{ person.image }}" alt="Schets van {{ person.name }}" class="team-sketch">
                <h3>{{ person.name }}</h3>
                <p class="role">{{ person.role }}</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<div class="sketch-divider"></div>

<!-- ==================== QUOTE ==================== -->
<section class="quote-section">
    <div class="fade-in">
        <p class="quote-text">"Wij geloven dat de verbinding met de natuur ons helpt om beter voor onszelf en voor de wereld te zorgen."</p>
        <p class="quote-author">&mdash; 't Hazelbos</p>
    </div>
</section>

<div class="sketch-divider"></div>

<!-- ==================== AGENDA ==================== -->
<section class="section" id="agenda">
    <div class="fade-in">
        <span class="section-label">agenda</span>
        <h2 class="section-title">Komende activiteiten</h2>

        <div class="agenda-list">
            {% if collections.agenda.length > 0 %}
                {% for item in collections.agenda %}
                <div class="agenda-item">
                    <div class="agenda-date">
                        <span class="agenda-day">{{ item.date | day }}</span>
                        <span class="agenda-month">{{ item.date | dutchMonth }}</span>
                    </div>
                    <div class="agenda-info">
                        <h3>{{ item.data.title }}</h3>
                        <p>{{ item.data.summary }}</p>
                    </div>
                </div>
                {% endfor %}
            {% else %}
                <p class="section-text" style="text-align: center;">Er zijn momenteel geen geplande activiteiten. Houd deze pagina in de gaten.</p>
            {% endif %}
        </div>
    </div>
</section>

<div class="sketch-divider"></div>

<!-- ==================== CONTACT ==================== -->
<section class="section" id="contact">
    <div class="fade-in">
        <span class="section-label">contact</span>
        <h2 class="section-title">Neem contact op</h2>

        <div class="contact-info" style="text-align: center;">
            <p><strong>'t Hazelbos</strong></p>
            <p>{{ site.address.street }}</p>
            <p>{{ site.address.postalCode }} {{ site.address.city }}</p>
            <p style="margin-top: 16px;">
                <a href="tel:{{ site.phone }}">{{ site.phoneDisplay }}</a>
            </p>
            <div style="margin-top: 20px;">
                <a href="mailto:{{ site.email }}?subject=Vraag%20via%20hazelbos.nl" class="btn btn-filled">Stuur een e-mail</a>
            </div>
        </div>
    </div>
</section>
