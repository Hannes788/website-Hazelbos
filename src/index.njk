<!-- ==================== INTRO ==================== -->
<section class="section hero-intro" id="top">
    <div class="fade-in">
        <h1 class="section-title">'t Hazelbos</h1>
        <p class="section-text">Anderhalve hectare voedselbos in de Achterhoek. Verblijf in natuurhuisje Acasia, huur de groepsruimte of kom het voedselbos ontdekken.</p>
        <div class="hero-buttons">
            <a href="#natuurhuisje" class="btn btn-filled">Bekijk het natuurhuisje</a>
            <a href="#voedselbos" class="btn">Ontdek het voedselbos</a>
        </div>
    </div>
</section>

<div class="sketch-divider"></div>

<!-- ==================== NATUURHUISJE (HOOFDPROPOSITIE) ==================== -->
<section class="section hero-section" id="natuurhuisje">
    <div class="fade-in">
        <div class="hero-split">
            <div class="hero-split-text">
                <span class="section-label">natuurhuisje</span>
                <h2 class="section-title">Natuurhuisje Acasia</h2>
                <p class="section-text">Ons biobased natuurhuisje, midden in het voedselbos. Omringd door groen en met veel privacy. Met zorg ingericht en alles wat je nodig hebt voor een ontspannen verblijf in de natuur.</p>
            </div>
            <div class="hero-split-image">
                <img src="/images/schetsen/schets%20huisje%20vervloeid.png" alt="Potloodschets van het natuurhuisje">
            </div>
        </div>

        <!-- Hoofdfoto -->
        <div class="acasia-hero-photo" style="margin-top: 50px;">
            <img loading="lazy" src="/images/fotos/acasia/huisje-3.jpg" alt="Natuurhuisje Acasia midden in het voedselbos">
        </div>

        <!-- Fotogalerij -->
        <div class="grid-3 gallery" style="margin-top: 24px;">
            <div class="gallery-item">
                <img loading="lazy" src="/images/fotos/acasia/woonkamer-glaswand.jpg" alt="Woonkamer met grote glaswand en uitzicht op het bos">
            </div>
            <div class="gallery-item">
                <img loading="lazy" src="/images/fotos/acasia/woonkamer-overzicht.jpg" alt="Eethoek en woonkamer">
            </div>
            <div class="gallery-item">
                <img loading="lazy" src="/images/fotos/acasia/keuken.jpg" alt="Volledig uitgeruste keuken">
            </div>
            <div class="gallery-item">
                <img loading="lazy" src="/images/fotos/acasia/uitzicht-bos.jpg" alt="Uitzicht vanuit het huisje op het bos">
            </div>
            <div class="gallery-item">
                <img loading="lazy" src="/images/fotos/acasia/slaapkamer-tweepersoons.jpg" alt="Slaapkamer met tweepersoons bed">
            </div>
            <div class="gallery-item">
                <img loading="lazy" src="/images/fotos/acasia/slaapkamer-bedden.jpg" alt="Slaapkamer met losse bedden">
            </div>
            <div class="gallery-item">
                <img loading="lazy" src="/images/fotos/acasia/badkamer-wastafel.jpg" alt="Badkamer met koperen kraan">
            </div>
            <div class="gallery-item">
                <img loading="lazy" src="/images/fotos/acasia/regendouche.jpg" alt="Regendouche">
            </div>
            <div class="gallery-item">
                <img loading="lazy" src="/images/fotos/acasia/spiegeltje.jpg" alt="Handgemaakt houten spiegeltje">
            </div>
        </div>

        <ul class="feature-list" style="margin-top: 40px;">
            <li><strong>Capaciteit:</strong> max. 5 personen</li>
            <li><strong>Faciliteiten:</strong> keuken, badkamer, terras met uitzicht op het voedselbos</li>
            <li><strong>Ligging:</strong> midden in het voedselbos, veel privacy</li>
        </ul>

        <!-- Boekingsmodule (tijdelijk uitgeschakeld) -->
        <div style="margin-top: 50px; text-align: center; padding: 40px 20px; background: rgba(0,0,0,0.03); border-radius: 8px;">
            <p class="section-text"><strong>Online boeken is binnenkort mogelijk.</strong></p>
            <p class="section-text" style="margin-top: 8px;">Neem gerust contact met ons op voor beschikbaarheid en reserveringen.</p>
            <a href="mailto:info@hazelbos.nl?subject=Boekingsaanvraag%20Acasia" class="btn btn-filled" style="margin-top: 16px;">Stuur een e-mail</a>
        </div>

        <a href="/natuurhuisje/" class="btn" style="margin-top: 30px;">Meer over Acasia</a>
    </div>
</section>

<div class="sketch-divider"></div>

<!-- ==================== VOEDSELBOS ==================== -->
<section class="section hero-section" id="voedselbos">
    <div class="fade-in hero-split">
        <div class="hero-split-text">
            <span class="section-label">voedselbos</span>
            <h2 class="section-title">Ons levende voedselbos</h2>
            <p class="section-text">Een divers ecosysteem waar fruitbomen, bessenstruiken, kruiden en groenten samen groeien. Een plek waar natuur en voedselproductie hand in hand gaan.</p>
        </div>
        <div class="hero-split-image">
            <img src="/images/schetsen/schets%20vervloeid%20perzik.png" alt="Potloodschets van een perzik aan de boom">
        </div>
    </div>

    <div class="grid-3 gallery">
        <div class="gallery-item">
            <img loading="lazy" src="/images/fotos/voedselbos/avondlicht-bomen.jpg" alt="Avondlicht door de bomen in het voedselbos">
        </div>
        <div class="gallery-item">
            <img loading="lazy" src="/images/fotos/voedselbos/vuurcirkel-ochtend.jpg" alt="Vuurcirkel bij zonsopkomst">
        </div>
        <div class="gallery-item">
            <img loading="lazy" src="/images/fotos/voedselbos/kas.jpg" alt="Kas in het voedselbos">
        </div>
        <div class="gallery-item">
            <img loading="lazy" src="/images/fotos/voedselbos/tomaten-kas.jpg" alt="Tomaten rijpen in de kas">
        </div>
        <div class="gallery-item">
            <img loading="lazy" src="/images/fotos/voedselbos/bessen.jpg" alt="Bessen aan de struik">
        </div>
        <div class="gallery-item">
            <img loading="lazy" src="/images/fotos/voedselbos/kornoelje.jpg" alt="Kornoelje in bloei">
        </div>
        <div class="gallery-item">
            <img loading="lazy" src="/images/fotos/voedselbos/bloem-zonsondergang.jpg" alt="Bloem bij zonsondergang">
        </div>
        <div class="gallery-item">
            <img loading="lazy" src="/images/fotos/voedselbos/bij-verbena.jpg" alt="Bij op verbena">
        </div>
        <div class="gallery-item">
            <img loading="lazy" src="/images/fotos/voedselbos/ochtendmist.jpg" alt="Ochtendmist in het voedselbos">
        </div>
    </div>

    <a href="/voedselbos/" class="btn" style="margin-top: 30px;">Meer over het voedselbos</a>
</section>

<div class="sketch-divider"></div>

<!-- ==================== GROEPSRUIMTE ==================== -->
<section class="section hero-section" id="groepsruimte">
    <div class="fade-in hero-split">
        <div class="hero-split-image">
            <img src="/images/schetsen/groepsruimte%20schets.png" alt="Potloodschets van de groepsruimte">
        </div>
        <div class="hero-split-text">
            <span class="section-label">groepsruimte</span>
            <h2 class="section-title">Vergaderen en samenkomen</h2>
            <p class="section-text">Een rustige ruimte van 60m² voor vergaderingen, brainstormsessies, workshops, cursussen en lezingen. Flexibel in te delen, geschikt voor maximaal 30 personen. Neem tijdens een pauze de tijd om het voedselbos te verkennen.</p>
        </div>
    </div>

    <div class="grid-3 gallery" style="margin-top: 30px;">
        <div class="gallery-item">
            <img loading="lazy" src="/images/fotos/groepsruimte/totaaloverzicht.jpg" alt="Totaaloverzicht van de ruimte">
        </div>
        <div class="gallery-item">
            <img loading="lazy" src="/images/fotos/groepsruimte/cirkelkleed-zithoek.jpg" alt="Cirkelkleed met zithoek en houtkachel">
        </div>
        <div class="gallery-item">
            <img loading="lazy" src="/images/fotos/groepsruimte/keuken-uitzicht.jpg" alt="Keuken met uitzicht op het groen">
        </div>
    </div>

    <a href="/groepsruimte/" class="btn btn-filled" style="margin-top: 30px;">Boekingsinformatie</a>
</section>

<div class="sketch-divider"></div>

<!-- ==================== NIEUWS (TEASER) ==================== -->
<section class="section" id="nieuws">
    <div class="fade-in">
        <span class="section-label">nieuws</span>
        <h2 class="section-title">Laatste nieuws</h2>

        <div class="news-grid">
            {% for item in collections.nieuws | head(2) %}
            <details class="news-card">
                <summary>
                    <p class="date">{{ item.date | dutchDate }}</p>
                    <h3>{{ item.data.title }}</h3>
                    <p>{{ item.data.summary }}</p>
                </summary>
                {% if item.data.image %}
                <img src="{{ item.data.image }}" alt="{{ item.data.imageAlt | default('') }}" style="width: 100%; margin: 16px 0;">
                {% endif %}
                {{ item.templateContent | safe }}
            </details>
            {% endfor %}
        </div>

        {% if collections.nieuws.length > 2 %}
        <a href="/nieuws/" class="btn" style="margin-top: 30px;">Alle nieuwsberichten</a>
        {% endif %}
    </div>
</section>

<div class="sketch-divider"></div>

<!-- ==================== WIE ZIJN WIJ ==================== -->
<section class="section" id="wie-zijn-wij">
    <div class="fade-in">
        <span class="section-label">wie zijn wij</span>
        <h2 class="section-title">De mensen achter 't Hazelbos</h2>
        <p class="section-text">{{ team.intro }}</p>
        <p class="section-text" style="margin-top: 16px;">{{ team.intro2 }}</p>

        <div class="team-row">
            {% for person in team.members %}
            <div class="team-person">
                <img src="{{ person.image }}" alt="Schets van {{ person.name }}" class="team-sketch">
                <h3>{{ person.name }}</h3>
                <p class="role">{{ person.role }}</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<div class="sketch-divider"></div>

<!-- ==================== QUOTE ==================== -->
<section class="quote-section">
    <div class="fade-in">
        <p class="quote-text">"Wij geloven dat de verbinding met de natuur ons helpt om beter voor onszelf en voor de wereld te zorgen."</p>
        <p class="quote-author">-- 't Hazelbos</p>
    </div>
</section>

<div class="sketch-divider"></div>

<!-- ==================== AGENDA ==================== -->
<section class="section" id="agenda">
    <div class="fade-in">
        <span class="section-label">agenda</span>
        <h2 class="section-title">Komende activiteiten</h2>

        <div class="agenda-list">
            {% if collections.agenda.length > 0 %}
                {% for item in collections.agenda %}
                <div class="agenda-item">
                    <div class="agenda-date">
                        <span class="agenda-day">{{ item.date | day }}</span>
                        <span class="agenda-month">{{ item.date | dutchMonth }}</span>
                    </div>
                    <div class="agenda-info">
                        <h3>{{ item.data.title }}</h3>
                        <p>{{ item.data.summary }}</p>
                    </div>
                </div>
                {% endfor %}
            {% else %}
                <p class="section-text" style="text-align: center;">Er zijn momenteel geen geplande activiteiten. Houd deze pagina in de gaten.</p>
            {% endif %}
        </div>
    </div>
</section>

<div class="sketch-divider"></div>

<!-- ==================== CONTACT ==================== -->
<section class="section" id="contact">
    <div class="fade-in">
        <span class="section-label">contact</span>
        <h2 class="section-title">Neem contact op</h2>

        <div class="contact-info" style="text-align: center;">
            <p><strong>'t Hazelbos</strong></p>
            <p>{{ site.address.street }}</p>
            <p>{{ site.address.postalCode }} {{ site.address.city }}</p>
            <p style="margin-top: 16px;">
                <a href="tel:{{ site.phone }}">{{ site.phoneDisplay }}</a>
            </p>
            <div style="margin-top: 20px;">
                <a href="mailto:{{ site.email }}?subject=Vraag%20via%20hazelbos.nl" class="btn btn-filled">Stuur een e-mail</a>
            </div>
        </div>
    </div>
</section>
