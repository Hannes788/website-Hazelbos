---
layout: base.njk
isHomepage: true
pageTitle: "'t Hazelbos — Voedselbos, Natuurhuisje & Groepsruimte in Zelhem"
pageDescription: "'t Hazelbos — Verblijf in natuurhuisje Acasia, ontdek ons voedselbos en huur onze groepsruimte in de Achterhoek."
canonical: "https://hazelbos.nl/"
og:
    title: "'t Hazelbos — Voedselbos, Natuurhuisje & Groepsruimte in Zelhem"
    description: "Anderhalve hectare voedselbos in de Achterhoek. Overnacht in biobased natuurhuisje Acasia of huur de groepsruimte."
    image: "https://hazelbos.nl/images/fotos/acasia/huisje-3.jpg"
    url: "https://hazelbos.nl/"
structuredData: >
    {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "'t Hazelbos",
        "description": "Voedselbos, vakantiehuisverhuur en groepsruimte in Zelhem, Achterhoek. Anderhalve hectare eetbaar bos met biobased vakantiehuis Acasia en vergaderruimte.",
        "url": "https://hazelbos.nl",
        "logo": "https://hazelbos.nl/images/logo%20zwart%20wit%20hazelbos.png",
        "telephone": "+31623502163",
        "email": "info@hazelbos.nl",
        "address": {
            "@type": "PostalAddress",
            "streetAddress": "Akkermansstraat 8",
            "postalCode": "7021 LW",
            "addressLocality": "Zelhem",
            "addressRegion": "Gelderland",
            "addressCountry": "NL"
        },
        "geo": {
            "@type": "GeoCoordinates",
            "latitude": 52.0058,
            "longitude": 6.3475
        },
        "founder": [
            { "@type": "Person", "name": "Johannes" },
            { "@type": "Person", "name": "Marjolein" }
        ],
        "areaServed": {
            "@type": "AdministrativeArea",
            "name": "Achterhoek, Gelderland"
        }
    }
---

<!-- ==================== INTRO ==================== -->
<section class="section hero-intro" id="top">
    <div class="fade-in">
        <h1 class="section-title">{{ homepage.intro.titel }}</h1>
        <p class="section-text">{{ homepage.intro.tekst }}</p>
    </div>
</section>

<!-- ==================== NATUURHUISJE (HOOFDPROPOSITIE) ==================== -->
<section class="section hero-section" id="natuurhuisje">
    <div class="fade-in">
        <div class="hero-split">
            <div class="hero-split-text">
                <span class="section-label">{{ homepage.natuurhuisje.label }}</span>
                <h2 class="section-title">{{ homepage.natuurhuisje.titel }}</h2>
                <p class="section-text">{{ homepage.natuurhuisje.tekst }}</p>
            </div>
            <div class="hero-split-image">
                <img src="/images/schetsen/schets%20huisje%20vervloeid.png" alt="Potloodschets van het natuurhuisje">
            </div>
        </div>

        <!-- Hoofdfoto -->
        <div class="acasia-hero-photo" style="margin-top: 50px;">
            <img loading="lazy" src="{{ homepage.natuurhuisje.hoofdfoto }}" alt="{{ homepage.natuurhuisje.hoofdfoto_alt }}">
        </div>

        <!-- Fotogalerij -->
        <div class="grid-3 gallery" style="margin-top: 24px;">
            {% for foto in homepage.natuurhuisje.fotos %}
            <div class="gallery-item">
                <img loading="lazy" src="{{ foto.src }}" alt="{{ foto.alt }}">
            </div>
            {% endfor %}
        </div>

        <ul class="feature-list" style="margin-top: 40px;">
            {% for kenmerk in homepage.natuurhuisje.kenmerken %}
            <li>{{ kenmerk }}</li>
            {% endfor %}
        </ul>

        <!-- Boekingsmodule Smoobu -->
        <div class="booking-widget" style="margin-top: 50px;">
            <div id="apartmentIframeHome">
                <script type="text/javascript" src="https://login.smoobu.com/js/Settings/BookingToolIframe.js"></script>
                <script>BookingToolIframe.initialize({"url": "https://login.smoobu.com/en/booking-tool/iframe/1685922", "baseUrl": "https://login.smoobu.com", "target": "#apartmentIframeHome"})</script>
            </div>
        </div>

        <a href="/natuurhuisje/" class="btn" style="margin-top: 30px;">Meer over Acasia</a>
    </div>
</section>

<div class="sketch-divider"></div>

<!-- ==================== VOEDSELBOS ==================== -->
<section class="section hero-section" id="voedselbos">
    <div class="fade-in hero-split">
        <div class="hero-split-text">
            <span class="section-label">{{ homepage.voedselbos.label }}</span>
            <h2 class="section-title">{{ homepage.voedselbos.titel }}</h2>
            <p class="section-text">{{ homepage.voedselbos.tekst }}</p>
        </div>
        <div class="hero-split-image">
            <img src="/images/schetsen/schets%20vervloeid%20perzik.png" alt="Potloodschets van een perzik aan de boom">
        </div>
    </div>

    <div class="grid-3 gallery">
        {% for foto in homepage.voedselbos.fotos %}
        <div class="gallery-item">
            <img loading="lazy" src="{{ foto.src }}" alt="{{ foto.alt }}">
        </div>
        {% endfor %}
    </div>

    <a href="/voedselbos/" class="btn" style="margin-top: 30px;">Meer over het voedselbos</a>
</section>

<div class="sketch-divider"></div>

<!-- ==================== GROEPSRUIMTE ==================== -->
<section class="section hero-section" id="groepsruimte">
    <div class="fade-in hero-split">
        <div class="hero-split-image">
            <img src="/images/schetsen/groepsruimte%20schets.png" alt="Potloodschets van de groepsruimte">
        </div>
        <div class="hero-split-text">
            <span class="section-label">{{ homepage.groepsruimte.label }}</span>
            <h2 class="section-title">{{ homepage.groepsruimte.titel }}</h2>
            <p class="section-text">{{ homepage.groepsruimte.tekst }}</p>
        </div>
    </div>

    <div class="grid-3 gallery" style="margin-top: 30px;">
        {% for foto in homepage.groepsruimte.fotos %}
        <div class="gallery-item">
            <img loading="lazy" src="{{ foto.src }}" alt="{{ foto.alt }}">
        </div>
        {% endfor %}
    </div>

    <a href="/groepsruimte/" class="btn btn-filled" style="margin-top: 30px;">Boekingsinformatie</a>
</section>

<div class="sketch-divider"></div>

<!-- ==================== NIEUWS (TEASER) ==================== -->
<section class="section" id="nieuws">
    <div class="fade-in">
        <span class="section-label">nieuws</span>
        <h2 class="section-title">Laatste nieuws</h2>

        <div class="news-grid">
            {% for item in collections.nieuws | head(2) %}
            <details class="news-card">
                <summary>
                    <p class="date">{{ item.date | dutchDate }}</p>
                    <h3>{{ item.data.title }}</h3>
                    <p>{{ item.data.summary }}</p>
                </summary>
                {% if item.data.image %}
                <img src="{{ item.data.image }}" alt="{{ item.data.imageAlt | default('') }}" style="width: 100%; margin: 16px 0;">
                {% endif %}
                {{ item.templateContent | safe }}
            </details>
            {% endfor %}
        </div>

        {% if collections.nieuws.length > 2 %}
        <a href="/nieuws/" class="btn" style="margin-top: 30px;">Alle nieuwsberichten</a>
        {% endif %}
    </div>
</section>

<div class="sketch-divider"></div>

<!-- ==================== WIE ZIJN WIJ ==================== -->
<section class="section" id="wie-zijn-wij">
    <div class="fade-in">
        <span class="section-label">wie zijn wij</span>
        <h2 class="section-title">De mensen achter 't Hazelbos</h2>
        <p class="section-text">{{ team.intro }}</p>
        <p class="section-text" style="margin-top: 16px;">{{ team.intro2 }}</p>

        <div class="team-row">
            {% for person in team.members %}
            <div class="team-person">
                <img src="{{ person.image }}" alt="Schets van {{ person.name }}" class="team-sketch">
                <h3>{{ person.name }}</h3>
                <p class="role">{{ person.role }}</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<div class="sketch-divider"></div>

<!-- ==================== QUOTE ==================== -->
<section class="quote-section">
    <div class="fade-in">
        <p class="quote-text">"{{ homepage.quote.tekst }}"</p>
        <p class="quote-author">-- {{ homepage.quote.auteur }}</p>
    </div>
</section>

<div class="sketch-divider"></div>

<!-- ==================== AGENDA ==================== -->
<section class="section" id="agenda">
    <div class="fade-in">
        <span class="section-label">agenda</span>
        <h2 class="section-title">Komende activiteiten</h2>

        <div class="agenda-list">
            {% if collections.agenda.length > 0 %}
                {% for item in collections.agenda %}
                <div class="agenda-item">
                    <div class="agenda-date">
                        <span class="agenda-day">{{ item.date | day }}</span>
                        <span class="agenda-month">{{ item.date | dutchMonth }}</span>
                    </div>
                    <div class="agenda-info">
                        <h3>{{ item.data.title }}</h3>
                        <p>{{ item.data.summary }}</p>
                    </div>
                </div>
                {% endfor %}
            {% else %}
                <p class="section-text" style="text-align: center;">Er zijn momenteel geen geplande activiteiten. Houd deze pagina in de gaten.</p>
            {% endif %}
        </div>
    </div>
</section>

<div class="sketch-divider"></div>

<!-- ==================== CONTACT ==================== -->
<section class="section" id="contact">
    <div class="fade-in">
        <span class="section-label">contact</span>
        <h2 class="section-title">Neem contact op</h2>

        <div class="contact-info" style="text-align: center;">
            <p><strong>'t Hazelbos</strong></p>
            <p>{{ site.address.street }}</p>
            <p>{{ site.address.postalCode }} {{ site.address.city }}</p>
            <p style="margin-top: 16px;">
                <a href="tel:{{ site.phone }}">{{ site.phoneDisplay }}</a>
            </p>
            <div style="margin-top: 20px;">
                <a href="mailto:{{ site.email }}?subject=Vraag%20via%20hazelbos.nl" class="btn btn-filled">Stuur een e-mail</a>
            </div>
        </div>
    </div>
</section>
