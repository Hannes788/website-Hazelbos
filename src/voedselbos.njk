---
layout: base.njk
pageTitle: "Voedselbos — Anderhalve hectare eetbaar bos | 't Hazelbos, Zelhem"
pageDescription: "'t Hazelbos is een voedselbos van ruim anderhalve hectare in Zelhem. Vrij van bestrijdingsmiddelen, vol eetbare bomen, struiken en planten."
canonical: "https://hazelbos.nl/voedselbos/"
og:
    title: "Voedselbos — Anderhalve hectare eetbaar bos | 't Hazelbos"
    description: "Voedselbos van ruim anderhalve hectare in Zelhem. Vrij van bestrijdingsmiddelen, vol eetbare bomen, struiken en planten."
    image: "https://hazelbos.nl/images/fotos/voedselbos/avondlicht-bomen.jpg"
    url: "https://hazelbos.nl/voedselbos/"
structuredData: >
    {
        "@context": "https://schema.org",
        "@type": "Place",
        "name": "'t Hazelbos — Voedselbos",
        "description": "Voedselbos van ruim anderhalve hectare in Zelhem, gemeente Bronckhorst. Vrij van chemische bestrijdingsmiddelen, met eetbare bomen, struiken en planten.",
        "url": "https://hazelbos.nl/voedselbos",
        "telephone": "+31623502163",
        "address": {
            "@type": "PostalAddress",
            "streetAddress": "Akkermansstraat 8",
            "postalCode": "7021 LW",
            "addressLocality": "Zelhem",
            "addressRegion": "Gelderland",
            "addressCountry": "NL"
        },
        "geo": {
            "@type": "GeoCoordinates",
            "latitude": 52.0058,
            "longitude": 6.3475
        },
        "additionalProperty": [
            { "@type": "PropertyValue", "name": "Oppervlakte", "value": "1,5 hectare" },
            { "@type": "PropertyValue", "name": "Soorten fruitbomen", "value": "50+" },
            { "@type": "PropertyValue", "name": "Eetbare planten", "value": "100+" },
            { "@type": "PropertyValue", "name": "Lagen in het bos", "value": "7" }
        ],
        "image": "https://hazelbos.nl/images/fotos/voedselbos/avondlicht-bomen.jpg",
        "containedInPlace": {
            "@type": "AdministrativeArea",
            "name": "Gemeente Bronckhorst, Achterhoek, Gelderland"
        }
    }
permalink: /voedselbos/
---

<!-- ==================== HERO ==================== -->
<section class="section" id="top">
    <div class="fade-in">
        <div class="hero-split">
            <div class="hero-split-text">
                <span class="section-label">{{ pagina_voedselbos.hero.label }}</span>
                <h1 class="section-title">{{ pagina_voedselbos.hero.titel }}</h1>
                <p class="section-text">{{ pagina_voedselbos.hero.tekst }}</p>
            </div>
            <div class="hero-split-image">
                <img src="/images/schetsen/schets%20vervloeid%20perzik.png" alt="Potloodschets van een perzik aan de boom">
            </div>
        </div>

        <div class="grid-3 gallery" style="margin-top: 40px;">
            {% for foto in pagina_voedselbos.hero.fotos %}
            <div class="gallery-item">
                <img loading="lazy" src="{{ foto.src }}" alt="{{ foto.alt }}">
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<div class="sketch-divider"></div>

<!-- ==================== WERKWIJZE ==================== -->
<section class="section">
    <div class="fade-in">
        <span class="section-label">{{ pagina_voedselbos.werkwijze.label }}</span>
        <h2 class="section-title">{{ pagina_voedselbos.werkwijze.titel }}</h2>
        <p class="section-text">{{ pagina_voedselbos.werkwijze.tekst }}</p>

        <div class="grid-3 gallery" style="margin-top: 40px;">
            {% for foto in pagina_voedselbos.werkwijze.fotos %}
            <div class="gallery-item">
                <img loading="lazy" src="{{ foto.src }}" alt="{{ foto.alt }}">
            </div>
            {% endfor %}
        </div>

        <div class="stats-row" style="margin-top: 40px;">
            {% for stat in pagina_voedselbos.werkwijze.stats %}
            <div class="stat-item">
                <div class="stat-number">{{ stat.nummer }}</div>
                <div class="stat-label">{{ stat.label }}</div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<div class="sketch-divider"></div>

<!-- ==================== HET LAND ==================== -->
<section class="section">
    <div class="fade-in">
        <span class="section-label">{{ pagina_voedselbos.land.label }}</span>
        <h2 class="section-title">{{ pagina_voedselbos.land.titel }}</h2>
        <p class="section-text">{{ pagina_voedselbos.land.tekst }}</p>
        {% if pagina_voedselbos.land.tekst2 %}
        <p class="section-text" style="margin-top: 16px;">{{ pagina_voedselbos.land.tekst2 }}</p>
        {% endif %}

        <div class="grid-3 gallery" style="margin-top: 40px;">
            {% for foto in pagina_voedselbos.land.fotos %}
            <div class="gallery-item">
                <img loading="lazy" src="{{ foto.src }}" alt="{{ foto.alt }}">
            </div>
            {% endfor %}
        </div>

        <div id="plattegrond" style="margin-top: 50px; text-align: center;">
            <h3 class="section-title" style="font-size: 1.6rem;">Plattegrond</h3>
            <img src="/images/plattegrond%20voedselbos.jpg" alt="Plattegrond van het voedselbos met genummerde bomen en planten" style="max-width: 100%; margin-top: 20px;">
            <img src="/images/legenda%20schets.png" alt="Legenda: overzicht van bomen en struiken in het voedselbos" style="max-width: 100%; margin-top: 20px;">
        </div>
    </div>
</section>

<div class="sketch-divider"></div>

<!-- ==================== WAT GROEIT LEEFT ==================== -->
<section class="section">
    <div class="fade-in">
        <span class="section-label">{{ pagina_voedselbos.verbond.label }}</span>
        <h2 class="section-title">{{ pagina_voedselbos.verbond.titel }}</h2>
        <p class="section-text">{{ pagina_voedselbos.verbond.tekst }}</p>
        {% if pagina_voedselbos.verbond.tekst2 %}
        <p class="section-text" style="margin-top: 16px;">{{ pagina_voedselbos.verbond.tekst2 }}</p>
        {% endif %}
    </div>
</section>

<div class="sketch-divider"></div>

<!-- ==================== EEN PLEK ==================== -->
<section class="section">
    <div class="fade-in">
        <span class="section-label">{{ pagina_voedselbos.plek.label }}</span>
        <h2 class="section-title">{{ pagina_voedselbos.plek.titel }}</h2>
        <p class="section-text">{{ pagina_voedselbos.plek.tekst }}</p>

        <div style="margin-top: 40px; text-align: center;">
            <a href="/natuurhuisje/" class="btn btn-filled">Bekijk het natuurhuisje</a>
            <a href="/groepsruimte/" class="read-more" style="margin-left: 20px;">groepsruimte &rarr;</a>
        </div>
    </div>
</section>

<div class="sketch-divider"></div>

<!-- ==================== CONTACT ==================== -->
<section class="section">
    <div class="fade-in">
        <span class="section-label">{{ pagina_voedselbos.contact.label }}</span>
        <h2 class="section-title">{{ pagina_voedselbos.contact.titel }}</h2>
        <p class="section-text">{{ pagina_voedselbos.contact.tekst }}</p>
        <div style="margin-top: 20px; text-align: center;">
            <a href="mailto:{{ site.email }}?subject=Vraag%20over%20het%20voedselbos" class="btn">Stuur een e-mail</a>
        </div>
    </div>
</section>
