---
layout: base.njk
pageTitle: "Nieuws — 't Hazelbos"
pageDescription: "Het laatste nieuws van 't Hazelbos. Updates over het voedselbos, natuurhuisje Acasia en onze activiteiten."
permalink: /nieuws/
---

<section class="section">
    <div class="fade-in">
        <span class="section-label">nieuws</span>
        <h1 class="section-title">Alle nieuwsberichten</h1>

        <div class="news-grid">
            {% for item in collections.nieuws %}
            <details class="news-card">
                <summary>
                    <p class="date">{{ item.date | dutchDate }}</p>
                    <h3>{{ item.data.title }}</h3>
                    <p>{{ item.data.summary }}</p>
                </summary>
                {% if item.data.image %}
                <img src="{{ item.data.image }}" alt="{{ item.data.imageAlt | default('') }}" style="width: 100%; margin: 16px 0;">
                {% endif %}
                {{ item.templateContent | safe }}
            </details>
            {% endfor %}
        </div>
    </div>
</section>
